# ── Telegram API credentials ──────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Get BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklm

# ── Admin configuration ───────────────────────────────────────────────────────
# Comma-separated Telegram user IDs of admins
ADMIN_IDS=123456789,987654321

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (relative to project root)
DATABASE_URL=bot.db

# ── Runtime settings (also configurable via bot commands) ─────────────────────
# These are overridden by /setgroup and /setfolder commands, but you can
# pre-fill them here for the first run.

# Supergroup ID for redemption announcements (starts with -100)
# Leave as 0 to skip group announcements
GROUP_ID=0
